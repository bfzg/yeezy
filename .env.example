# Copy this file to `.env.local` (recommended) or `.env`, then replace placeholders
# with your own credentials. Never commit real secrets to git.
#
# Next.js loads `.env.local` with higher priority than `.env` in local development.

# Fixed shipping fee in USD (decimal). Used at checkout.
SHIPPING_FLAT_RATE_USD=24.99

# Default admin created when the local database has no admin user yet.
DEFAULT_ADMIN_EMAIL=admin@yezi.local
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=YEZI ADMIN

# Optional absolute path for admin-uploaded product images.
# UPLOAD_DIR=/var/www/dropmini/public/uploads

# Cart checkout gate. true = show the early-access overlay and disable checkout;
# false = hide the overlay and allow checkout fields/payment buttons.
NEXT_PUBLIC_CHECKOUT_PAUSED=false

# Public storefront SEO and contact settings.
NEXT_PUBLIC_SITE_NAME=DropMini
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_DESCRIPTION=DropMini is a global shop for collectible plush dolls, military tank models, aircraft miniatures, and display-ready hobby pieces.
NEXT_PUBLIC_CONTACT_EMAIL=hello@yezi.shop
# NEXT_PUBLIC_CONTACT_INSTAGRAM=@yourbrand
# NEXT_PUBLIC_CONTACT_WHATSAPP=+1 000 000 0000
# NEXT_PUBLIC_CONTACT_TIKTOK=@yourbrand
# NEXT_PUBLIC_CONTACT_TWITTER=@yourbrand
# Optional Google Analytics 4 measurement ID.
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Stripe secret key (optional; required only if Apple Pay via Stripe is enabled).
# Sandbox example:
STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key

# PayPal REST API credentials from https://developer.paypal.com/dashboard/
# Use Sandbox credentials for local development.
PAYPAL_CLIENT_ID=your_sandbox_or_live_client_id
PAYPAL_SECRET=your_sandbox_or_live_secret

# PayPal REST API base URL — pick ONE environment:
# Sandbox (local dev):
PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com
# Live (production only, after PayPal app review):
# PAYPAL_API_BASE_URL=https://api-m.paypal.com

# Optional PayPal webhook ID for server-side payment confirmation.
# PAYPAL_WEBHOOK_ID=your_webhook_id_from_paypal_dashboard

# Apple Pay (optional, disabled by default)
NEXT_PUBLIC_APPLE_PAY_ENABLED=false
APPLE_PAY_MERCHANT_ID=merchant.com.example.store
